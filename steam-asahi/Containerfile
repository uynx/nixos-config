FROM quay.io/fedora/fedora-minimal@sha256:c5cee2279ec60146ea8123fabf65d493c26f8714fca4a209ca4024f5e386420c

RUN dnf install -y "dnf5-command(copr)" && \
    dnf copr enable -y @asahi/fedora-remix-scripts && \
    dnf copr enable -y @asahi/steam && \
    dnf install -y \
      asahi-platform-metapackage-fex-0-29.fc44.aarch64 \
      muvm-0.6.0-3.fc44.aarch64 \
      fex-emu-2604-1.fc44.aarch64 \
      'fex-emu-rootfs-fedora-44^20260410.n.0-1.fc44.noarch' \
      virglrenderer-1.3.0-1.fc44.aarch64 \
      mesa-dri-drivers-26.1.4-1.fc44.aarch64 \
      mesa-vulkan-drivers-26.1.4-1.fc44.aarch64 \
      gtk2-2.24.33-25.fc44.aarch64 \
      ibus-1.5.34-2.fc44.aarch64 \
      NetworkManager-1.56.1-2.fc44.aarch64 \
      openal-soft-1.24.2-6.fc44.aarch64 \
      libvdpau-1.5-11.fc44.aarch64 \
      fontconfig-devel-2.17.0-4.fc44.aarch64 \
      freetype-devel-2.14.3-1.fc44.aarch64 \
      harfbuzz-devel-14.1.0-2.fc44.aarch64 \
      libX11-devel-1.8.13-1.fc44.aarch64 \
      libXcomposite-devel-0.4.6-7.fc44.aarch64 \
      libXcursor-devel-1.2.3-4.fc44.aarch64 \
      libXext-devel-1.3.6-5.fc44.aarch64 \
      libXfixes-devel-6.0.1-7.fc44.aarch64 \
      libXi-devel-1.8.3-1.fc44.aarch64 \
      libXinerama-devel-1.1.5-10.fc44.aarch64 \
      libXrandr-devel-1.5.4-7.fc44.aarch64 \
      libXrender-devel-0.9.12-4.fc44.aarch64 \
      libXxf86vm-devel-1.1.6-4.fc44.aarch64 \
      libxkbcommon-devel-1.13.1-2.fc44.aarch64 \
      mesa-libGL-devel-26.1.4-1.fc44.aarch64 \
      steam-0-14.fc44.noarch \
      vulkan-loader-devel-1.4.341.0-1.fc44.aarch64 \
      xorg-x11-server-Xwayland-24.1.13-1.fc44.aarch64 && \
    dnf clean all && \
    rm -rf /var/cache/dnf/* /tmp/* /var/tmp/*

# FEX currently stalls this game's 32-bit Unity 5.6 player. Build Box64 with
# Box32 so Proton's Steam bridge and Wine helpers can run through Venus/Zink.
RUN dnf install -y \
      cmake-4.3.0-1.fc44.aarch64 \
      gcc-16.1.1-2.fc44.aarch64 \
      gcc-c++-16.1.1-2.fc44.aarch64 \
      make-4.4.1-12.fc44.aarch64 && \
    python3 -c 'import requests; open("/tmp/box64.tar.gz", "wb").write(requests.get("https://github.com/ptitSeb/box64/archive/a107c2a52b97ae0a40b8e9f1dee0f9d1456bba2e.tar.gz").content)' && \
    echo '05aae4d7e310780a80abe038bb081697f6525ac8a246c07e80e1790954182ca5  /tmp/box64.tar.gz' | sha256sum -c - && \
    mkdir -p /tmp/box64 && \
    python3 -c 'import tarfile; archive=tarfile.open("/tmp/box64.tar.gz"); archive.extractall("/tmp/box64", filter="data")' && \
    cmake \
      -S /tmp/box64/box64-a107c2a52b97ae0a40b8e9f1dee0f9d1456bba2e \
      -B /tmp/box64/build \
      -D M1=ON \
      -D BOX32=ON \
      -D NOGIT=ON \
      -D CMAKE_BUILD_TYPE=Release \
      -D CMAKE_INSTALL_PREFIX=/usr/local && \
    cmake --build /tmp/box64/build --parallel && \
    cmake --install /tmp/box64/build && \
    dnf remove -y cmake gcc gcc-c++ make && \
    dnf clean all && \
    rm -rf /var/cache/dnf/* /tmp/* /var/tmp/*

# Fedora's wrapper normally downloads this into mutable user state on first
# launch. Bake the fixed, hash-verified Valve bootstrap into the image instead.
RUN python3 -c 'import requests; open("/tmp/steam.tar.gz", "wb").write(requests.get("https://repo.steampowered.com/steam/archive/stable/steam_1.0.0.81.tar.gz").content)' && \
    echo '1a26b9d7cdace09e04dc86b511e0b9923257f664a5b6cafe6fed5e46d117b4f9  /tmp/steam.tar.gz' | sha256sum -c - && \
    mkdir -p /opt/fex-steam && \
    python3 -c 'import tarfile; names=["steam-launcher/steam_subscriber_agreement.txt", "steam-launcher/bin_steam.sh", "steam-launcher/bootstraplinux_ubuntu12_32.tar.xz"]; archive=tarfile.open("/tmp/steam.tar.gz"); archive.extractall("/opt/fex-steam", members=[archive.getmember(name) for name in names], filter="data")' && \
    rm /tmp/steam.tar.gz

# Valve's ARM64 public beta avoids running Steam's desktop UI through FEX. The
# client updates this bootstrap in persistent user state after first launch.
RUN python3 -c 'import requests; open("/tmp/steam-arm64.zip", "wb").write(requests.get("https://client-update.steamstatic.com/bins_linuxarm64_linuxarm64.zip.f122d0dc522cbd4d450fcfebc3552274b66b82e0").content)' && \
    echo 'a61e993476fa4e06b8a50f29f7bff9211367be7cf57c8bacb30544e384feaf15  /tmp/steam-arm64.zip' | sha256sum -c - && \
    mkdir -p /opt/steam-arm64 && \
    python3 -c 'import zipfile; zipfile.ZipFile("/tmp/steam-arm64.zip").extractall("/opt/steam-arm64")' && \
    chmod -R 0755 /opt/steam-arm64/steamrtarm64 && \
    rm /tmp/steam-arm64.zip

# The Asahi Steam wrapper's Qt bootstrap splash is oversized on this desktop.
# Steam itself remains unchanged; only the wrapper's transient splash is disabled.
RUN sed -i 's/^show_splash = True/show_splash = False/' /usr/bin/steam

# muvm's --execute-pre accepts an executable path (without arguments). Run
# this as root in the guest before Steam so large Windows games have enough
# virtual memory map slots.
COPY steam-guest-tune /usr/local/libexec/steam-guest-tune
RUN chmod 0755 /usr/local/libexec/steam-guest-tune

CMD ["/bin/bash"]
